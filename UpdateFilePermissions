# Import OS libary.
import os

# Define permissions level as a parameter.
# chmod permissions documentation: https://www.december.com/unix/ref/chmod.html
# 660 = You and the defined group can read and write to the file.
# 777 = Everybody can read, write to, or execute.

s = '660'

# Set the file path.
# Change this out for linking to Azure storage.
file_path = r'C:\Users\Iqbal Khan\OneDrive - Microsoft\Desktop\Test File For Permissions.txt'

# Run the permissions update function, pulling in the file_path and permission level parameters.
os.chmod(file_path, int(s, base=8))

# Check file for read access.
os.access(file_path, os.R_OK)

# Check file for write access.
os.access(file_path, os.W_OK)
